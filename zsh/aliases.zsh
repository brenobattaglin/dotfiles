# Modernized Zsh Aliases

# General
alias l='ls -lah'
alias ll='ls -lh'
alias ...='cd ../..'
alias ....='cd ../../..'

# Git
alias gst='git status'
alias gad='git add'
alias gcm='git commit -m'
alias gpl='git pull'
alias gps='git push'

# System
alias reload='source ~/.zshrc'
alias path='echo $PATH | tr ":" "\n"'

# Dotfiles
alias dotfiles='cd ~/Developer/dotfiles'
